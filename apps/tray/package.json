{
  "name": "@omniscribe/tray",
  "version": "0.1.0",
  "private": true,
  "description": "OmniScribe system tray app",
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "concurrently \"tsc -w -p tsconfig.electron.json\" \"wait-on dist/electron/main.js && electron .\"",
    "build": "tsc -p tsconfig.electron.json && tsc -p tsconfig.renderer.json",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:renderer": "tsc -p tsconfig.renderer.json",
    "start": "electron .",
    "clean": "rm -rf dist",
    "package": "electron-builder --win --config electron-builder.yml"
  },
  "dependencies": {
    "electron-store": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "concurrently": "^9.1.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.0",
    "typescript": "^5.7.0",
    "wait-on": "^8.0.0"
  }
}
