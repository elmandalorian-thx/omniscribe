# Supabase sync (optional — works offline without these)
OMNISCRIBE_SUPABASE_URL=https://your-project.supabase.co
OMNISCRIBE_SUPABASE_ANON_KEY=your-anon-key
OMNISCRIBE_SUPABASE_SERVICE_KEY=your-service-role-key

# Groq fallback (optional — only needed if no local GPU)
OMNISCRIBE_GROQ_API_KEY=your-groq-key

# OpenAI embeddings (optional — for sync-time embedding generation)
OMNISCRIBE_OPENAI_API_KEY=sk-your-key

# Whisper model (default: large-v3 for CUDA, small for CPU)
# OMNISCRIBE_WHISPER_MODEL=large-v3
# OMNISCRIBE_WHISPER_DEVICE=auto

# Daemon API
OMNISCRIBE_API_HOST=127.0.0.1
OMNISCRIBE_API_PORT=52849
